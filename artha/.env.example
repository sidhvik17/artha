# Copy this file to  artha/.env  and fill in your key.
# Free Gemini API key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=# YOUR_GEMINI_API_KEY
# Keep FALSE to use the AI Studio key above (TRUE only for Vertex AI + gcloud auth).
GOOGLE_GENAI_USE_VERTEXAI=FALSE
# Any Gemini model available to your key.
MODEL=gemini-2.5-flash